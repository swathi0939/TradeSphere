# Copy this file to .env.local (gitignored) and adjust as needed. All
# variables are optional — every one has a safe default in src/config/env.ts.

# Displayed on the Health Check page and available app-wide via src/config/env.ts.
VITE_APP_NAME=TradeSphere

# Should mirror package.json's "version" field.
VITE_APP_VERSION=0.0.0

# Multiplier applied to every mock service's simulated network latency.
# 0 = instant responses (useful for demos/QA), 1 = unchanged (default), >1 = slower/simulated poor network.
VITE_MOCK_DELAY_MULTIPLIER=1
